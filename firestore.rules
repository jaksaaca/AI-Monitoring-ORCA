rules_version = '2';

// ================================================
//  ORCA Host Monitoring - Firestore Security Rules
//  Development Mode (Open Rules)
//  Author: Jaksa Setia Alam
// ================================================

service cloud.firestore {
  match /databases/{database}/documents {
    // Membuka semua akses baca dan tulis untuk mempermudah development
    // TODO: Pasang kembali rules strict saat naik ke Production
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
